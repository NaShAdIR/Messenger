
MDScreen:
    name: "registration_screen"

    username: Username
    surname: Surname
    password: Password
    icon: icon

    FitImage:
        source: r".\Images\Fitimage.png"

    MDIconButton:
        icon: "arrow-left-bold-circle"# "./images/arrow-left-circle.png"
        pos_hint: {"center_x": .07, "center_y": .90}
        icon_size: "60sp"
        on_release:
            root.manager.transition.direction = 'right'
            root.manager.current = 'login'

    MDTextField:
        id: Username
        icon_right: "account"
        size_hint_x: None
        width: "320dp"
        mode: "fill"
        fill_color_normal: (1, 1, 1, 0.1)
        fill_color_focus: (1, 1, 1, 0.3)
        hint_text: "Имя"
        pos_hint: {"center_x": .5, "center_y": .66}
        font_size: "18sp"
        hint_text_color_focus: "black"
        text_color_focus: "black"

    MDTextField:
        id: Surname
        icon_right: "account"
        size_hint_x: None
        width: "320dp"
        mode: "fill"
        fill_color_normal: (1, 1, 1, 0.1)
        fill_color_focus: (1, 1, 1, 0.3)
        hint_text: "Фамилие"
        pos_hint: {"center_x": .5, "center_y": .54}
        font_size: "18sp"
        hint_text_color_focus: "black"
        text_color_focus: "black"

    #MDTextField:
        #id: Phone_number
        #icon_right: "phone"
        #size_hint_x: None
        #width: "320dp"
        #mode: "fill"
        #fill_color_normal: (1, 1, 1, 0.1)
        #fill_color_focus: (1, 1, 1, 0.3)
        #hint_text: "Номер телефона"
        #pos_hint: {"center_x": .5, "center_y": .42}
        #font_size: "18sp"
        #hint_text_color_focus: "black"
        #text_color_focus: "black"

    MDRelativeLayout:
        MDTextField:
            id: Password
            size_hint_x: None
            width: "320dp"
            mode: "fill"
            fill_color_normal: (1, 1, 1, 0.1)
            fill_color_focus: (1, 1, 1, 0.3)
            hint_text: "Password"
            pos_hint: {"center_x": .5, "center_y": .42}
            #pos: 165, 250
            password: True
            font_size: "18sp"
            hint_text_color_focus: "black"
            text_color_focus: "black"

        MDIconButton:
            icon: "eye-off"
            theme_text_color: "Hint"
            pos_hint: {"center_x": .73, "center_y": .42}
            on_release:
                Password.password = False if Password.password is True else True

    # RoundIcon:
    MDIconButton:
        icon_size: '110sp'
        pos_hint: {"center_x": .5, "center_y": .85}

        # size_hint: (None, None)
        # icon_radius: (50, 50, 50, 50)
        # id: icon
        # icon: "account"# "./images/user.png"

        on_release:
            app.change_icon()


    FitImage:
        id: icon
        source: "./images/user.png"
        pos_hint: {"center_x": .5, "center_y": .85}
        size_hint: .19, .19
        radius: (55, 55, 55, 55)

    MDFillRoundFlatButton:
        text: "Зарегестрироваться"
        pos_hint: {'center_x': .5, 'center_y': .1}
        size_hint_y: .1
        size_hint_x: .35
        md_bg_color: 1, 1, 1, 0.1
        on_release:
            app.registration()


